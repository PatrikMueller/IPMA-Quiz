      "question": {
        "type": "rich-text",
        "content": [
          { "type": "text", "value": "What is the primary role of a project manager in the initiation phase?" }
        ]
      },
      "options": [
        {
          "type": "text",
          "content": [
            { "type": "text", "value": "Define project scope and objectives" }
          ]
        },
        {
          "type": "text",
          "content": [
            { "type": "text", "value": "Execute project deliverables" }
          ]
        },
        {
          "type": "text",
          "content": [
            { "type": "text", "value": "Monitor and control project performance" }
          ]
        },
        {
          "type": "text",
          "content": [
            { "type": "text", "value": "Close project and document lessons learned" }
          ]
        }
      ],
      "multiple": false,
      "correctAnswers": [0],
      "explanation": [
        { "type": "text", "value": "During the initiation phase, the project manager's primary role is to define the project scope, objectives, and stakeholder requirements. This establishes the foundation for all subsequent project activities." }
